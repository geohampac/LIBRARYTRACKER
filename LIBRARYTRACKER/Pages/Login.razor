@page "/login"
@using System.ComponentModel.DataAnnotations
@using MudBlazor

<PageTitle>Login – Library Tracker</PageTitle>

<MudThemeProvider Theme="_theme" />

<div class="auth-bg">
    <MudCard Elevation="20" Class="auth-card">

        <!-- ══ BANNER ══ -->
        <div class="banner-wrap">
            <svg viewBox="0 0 800 380" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice" class="banner-svg">
                <defs>
                    <linearGradient id="sk" x1="0" y1="0" x2="1" y2="1">
                        <stop offset="0%" stop-color="#1e8c5e" />
                        <stop offset="55%" stop-color="#4db87a" />
                        <stop offset="100%" stop-color="#c8e04a" />
                    </linearGradient>
                    <linearGradient id="mt" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#145c3a" />
                        <stop offset="100%" stop-color="#0d4028" />
                    </linearGradient>
                    <linearGradient id="du" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#b8d43e" />
                        <stop offset="100%" stop-color="#92b030" />
                    </linearGradient>
                </defs>
                <rect width="800" height="380" fill="url(#sk)" />
                <circle cx="110" cy="80" r="52" fill="#38b06a" opacity="0.68" />
                <ellipse cx="580" cy="58" rx="70" ry="24" fill="rgba(255,255,255,0.12)" />
                <ellipse cx="650" cy="42" rx="44" ry="16" fill="rgba(255,255,255,0.09)" />
                <path d="M0,260 L100,110 L200,200 L320,80 L440,190 L560,72 L680,158 L800,95 L800,380 L0,380Z" fill="url(#mt)" opacity="0.58" />
                <path d="M0,330 Q90,248 220,295 Q360,222 500,282 Q620,228 800,268 L800,380 L0,380Z" fill="url(#du)" opacity="0.90" />
                <path d="M0,380 Q180,345 380,368 Q580,340 800,362 L800,380Z" fill="#82a028" opacity="0.75" />
                <path d="M440,92 Q447,84 454,92 Q461,84 468,92" stroke="#dff09a" stroke-width="2.4" fill="none" stroke-linecap="round" />
                <path d="M640,128 Q646,121 652,128 Q658,121 664,128" stroke="#dff09a" stroke-width="2" fill="none" stroke-linecap="round" />
            </svg>

            <div class="banner-content">
                <div class="banner-header">
                    <div>
                        <MudText Typo="Typo.h3" Class="banner-title">Library Tracker System</MudText>
                        <MudText Typo="Typo.body1" Class="banner-subtitle">
                            Manage your books, track borrowings, and stay organized — all in one place.
                        </MudText>
                    </div>
                    <img src="data:image/png;base64," alt="Logo" class="banner-logo" />
                </div>
                <div class="banner-link-row">
                    <MudLink Href="/register" Underline="Underline.None" Class="banner-link">Create Account</MudLink>
                </div>
            </div>
        </div>

        <!-- ══ FORM ══ -->
        <MudCardContent Class="form-content">
            <MudText Typo="Typo.h5" Align="Align.Center" Class="form-heading">USER LOGIN</MudText>

            <EditForm Model="@_model" OnValidSubmit="HandleLogin">
                <DataAnnotationsValidator />

                <div class="field-wrap">
                    <div class="pill-input-wrap">
                        <span class="pill-icon"><MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Medium" Style="color:rgba(255,255,255,0.88);" /></span>
                        <InputText @bind-Value="_model.Username" placeholder="Username" class="pill-input" />
                    </div>
                    <ValidationMessage For="@(() => _model.Username)" class="val-msg" />
                </div>

                <div class="field-wrap">
                    <div class="pill-input-wrap">
                        <span class="pill-icon"><MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Medium" Style="color:rgba(255,255,255,0.88);" /></span>
                        <InputText @bind-Value="_model.Password" type="password" placeholder="Password" class="pill-input" />
                    </div>
                    <ValidationMessage For="@(() => _model.Password)" class="val-msg" />
                </div>

                <div class="options-row">
                    <label class="remember-label">
                        <input type="checkbox" @bind="_remember" class="small-check" />
                        <span>Remember me</span>
                    </label>
                    <a href="/forgot-password" class="forgot-link">Forgot Password?</a>
                </div>

                <MudStack AlignItems="AlignItems.Center" Class="mt-6">
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Class="submit-btn">
                        Login
                    </MudButton>
                </MudStack>
            </EditForm>
        </MudCardContent>

    </MudCard>
</div>

@code {
    private LoginModel _model = new();
    private bool _remember = false;

    private MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight { Primary = "#1a7a50", PrimaryDarken = "#155f3e", Surface = "#ffffff" }
    };

    private void HandleLogin() { }

    private class LoginModel
    {
        [Required(ErrorMessage = "Username is required")]
        public string Username { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required")]
        public string Password { get; set; } = string.Empty;
    }
}

<style>
    .auth-bg {
        min-height: 100vh;
        background: linear-gradient(135deg,#1e8c5e 0%,#4db87a 45%,#c8e04a 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 32px 20px;
    }

    .auth-card {
        width: 680px !important;
        max-width: 96vw;
        border-radius: 28px !important;
        overflow: hidden;
    }

    .banner-wrap {
        position: relative;
        height: 360px;
        overflow: hidden;
    }

    .banner-svg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
    }

    .banner-content {
        position: relative;
        z-index: 2;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 44px 52px 26px;
    }

    .banner-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 20px;
    }

    .banner-logo {
        width: 90px;
        height: 90px;
        object-fit: contain;
        border-radius: 12px;
        background: rgba(255,255,255,0.10);
        padding: 6px;
        flex-shrink: 0;
    }

    .banner-title {
        color: #ffffff !important;
        font-family: 'Georgia',serif !important;
        font-weight: 700 !important;
        font-size: 2.4rem !important;
        text-shadow: 0 2px 12px rgba(0,0,0,0.22);
        margin-bottom: 12px !important;
        line-height: 1.15 !important;
    }

    .banner-subtitle {
        color: rgba(255,255,255,0.92) !important;
        font-size: 1rem !important;
        line-height: 1.6 !important;
        max-width: 440px;
    }

    .banner-link-row {
        text-align: center;
    }

    .banner-link {
        color: rgba(255,255,255,0.95) !important;
        font-size: 1rem !important;
        letter-spacing: 0.3px;
    }

    .form-content {
        background: #ffffff;
        padding: 40px 56px 48px !important;
    }

    .form-heading {
        color: #1a7a50 !important;
        font-weight: 700 !important;
        letter-spacing: 2.5px !important;
        text-transform: uppercase;
        margin-bottom: 30px !important;
    }

    .field-wrap {
        margin-bottom: 20px;
    }

    .pill-input-wrap {
        display: flex;
        align-items: center;
        background-color: #2e9e6a;
        border-radius: 50px;
        padding: 0 22px;
        height: 58px;
        gap: 12px;
        transition: background-color 0.2s,box-shadow 0.2s;
    }

        .pill-input-wrap:focus-within {
            background-color: #236e4a;
            box-shadow: 0 0 0 3px rgba(46,158,106,0.30);
        }

    .pill-icon {
        display: flex;
        align-items: center;
        flex-shrink: 0;
    }

    .pill-input {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        color: #ffffff;
        font-size: 1.05rem;
        font-family: 'Segoe UI',sans-serif;
        letter-spacing: 0.2px;
    }

        .pill-input::placeholder {
            color: rgba(255,255,255,0.75);
            font-size: 1rem;
        }

    .val-msg {
        color: #c62828;
        font-size: 0.82rem;
        margin-top: 5px;
        padding-left: 18px;
        display: block;
    }

    .options-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 6px;
    }

    .remember-label {
        display: flex;
        align-items: center;
        gap: 9px;
        font-size: 0.95rem;
        color: #444;
        cursor: pointer;
        user-select: none;
    }

    .small-check {
        width: 16px;
        height: 16px;
        accent-color: #1a7a50;
        cursor: pointer;
    }

    .forgot-link {
        font-size: 0.95rem;
        color: #444;
        text-decoration: none;
    }

        .forgot-link:hover {
            color: #1a7a50;
            text-decoration: underline;
        }

    .submit-btn {
        border-radius: 12px !important;
        min-width: 220px !important;
        height: 54px !important;
        font-size: 1.1rem !important;
        letter-spacing: 1px !important;
        font-weight: 700 !important;
    }
</style>
