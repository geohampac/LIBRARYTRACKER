@page "/dashboard"
@using MudBlazor

<PageTitle>Dashboard – Library Tracker</PageTitle>

<MudThemeProvider Theme="_theme" />

<div class="db-root">

    <!-- TOP BAR -->
    <header class="db-topbar">
        <div class="db-topbar-left">
            <div class="db-logo-pill">
                <MudIcon Icon="@Icons.Material.Filled.MenuBook" Class="db-logo-icon" />
            </div>
            <div class="db-brand">
                <span class="db-brand-name">Library Tracker</span>
                <span class="db-brand-sub">Management System</span>
            </div>
        </div>
    </header>

    <!-- HERO -->
    <section class="db-hero">
        <div class="db-hero-content">
            <h1 class="db-hero-title">Welcome back 👋</h1>
            <p class="db-hero-sub">Manage your library resources easily.</p>
        </div>
    </section>

    <!-- BODY -->
    <div class="db-body">

        <div class="db-cards-grid">

            <a href="/book-review" class="db-card">
                <MudIcon Icon="@Icons.Material.Filled.RateReview" />
                <p>Book Review</p>
            </a>

            <a href="/book-items" class="db-card">
                <MudIcon Icon="@Icons.Material.Filled.LibraryBooks" />
                <p>Book Items</p>
            </a>

            <a href="/book-transaction" class="db-card">
                <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" />
                <p>Transactions</p>
            </a>

            <a href="/book-borrow" class="db-card">
                <MudIcon Icon="@Icons.Material.Filled.ImportContacts" />
                <p>Borrow</p>
            </a>

        </div>

    </div>
</div>

@code {
    private MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#1a7a50",
            Background = "#f0f7f4"
        }
    };
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap');

    .db-root {
        font-family: 'DM Sans', sans-serif;
        background: #f0f7f4;
        min-height: 100vh;
    }

    /* TOP BAR */
    .db-topbar {
        display: flex;
        justify-content: space-between;
        padding: 12px 40px;
        background: #fff;
    }

    /* HERO */
    .db-hero {
        height: 200px;
        background: linear-gradient(135deg, #0d5c3a, #2eb87a);
        color: #fff;
        display: flex;
        align-items: center;
        padding-left: 40px;
    }

    .db-hero-title {
        font-size: 2rem;
        margin: 0;
    }

    .db-hero-sub {
        opacity: 0.8;
    }

    /* CARDS */
    .db-cards-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        padding: 40px;
    }

    .db-card {
        background: #fff;
        padding: 20px;
        border-radius: 12px;
        text-decoration: none;
        color: #000;
        transition: 0.2s;
    }

        .db-card:hover {
            transform: translateY(-5px);
        }

    /* FIXED KEYFRAMES */
    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    /* FIXED MEDIA QUERIES */
    @@media (max-width: 1100px) {
        .db-cards-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 700px) {
        .db-cards-grid {
            grid-template-columns: 1fr;
        }
    }
</style>