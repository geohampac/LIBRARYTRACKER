@page "/dashboard"
@using MudBlazor
@inject NavigationManager Navigation

<PageTitle>Dashboard – Library Tracker</PageTitle>

<MudThemeProvider Theme="_theme" />

<div class="app-shell">

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <div class="sidebar-logo">
            <div class="sidebar-logo-icon">
                <MudIcon Icon="@Icons.Material.Filled.MenuBook" />
            </div>
            <div>
                <span class="sidebar-brand">Library</span>
                <span class="sidebar-brand-sub">Tracker System</span>
            </div>
        </div>

        <div class="sidebar-divider"></div>

        <nav class="sidebar-nav">
            <p class="sidebar-nav-label">Main Menu</p>

            <a href="/dashboard" class="nav-item active">
                <MudIcon Icon="@Icons.Material.Filled.Dashboard" />
                <span>Dashboard</span>
            </a>

            <a href="/book-review" class="nav-item">
                <MudIcon Icon="@Icons.Material.Filled.RateReview" />
                <span>Book Review</span>
            </a>

            <a href="/book-items" class="nav-item">
                <MudIcon Icon="@Icons.Material.Filled.LibraryBooks" />
                <span>Book List</span>
            </a>

            <a href="/book-transaction" class="nav-item">
                <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" />
                <span>Book Transaction</span>
            </a>

            <a href="/book-borrow" class="nav-item">
                <MudIcon Icon="@Icons.Material.Filled.ImportContacts" />
                <span>Book Borrow</span>
            </a>
        </nav>

        <div class="sidebar-footer">
            <div class="sidebar-user">
                <div class="sidebar-avatar">A</div>
                <div>
                    <span class="sidebar-user-name">Admin</span>
                    <span class="sidebar-user-role">Librarian</span>
                </div>
            </div>
        </div>
    </aside>

    <!-- MAIN -->
    <div class="main-area">

        <!-- TOPBAR -->
        <header class="topbar">
            <div>
                <h2 class="topbar-title">Dashboard</h2>
                <p class="topbar-sub">Welcome back, Admin!</p>
            </div>

            <button class="logout-btn" @onclick="Logout">
                <MudIcon Icon="@Icons.Material.Filled.Logout" />
                Logout
            </button>
        </header>

        <!-- HERO -->
        <div class="hero-banner">
            <div class="hero-text">
                <h1 class="hero-title">Library Tracker System</h1>
                <p class="hero-sub">
                    Manage your books, track borrowings, and stay organized.
                </p>
            </div>
        </div>

        <!-- CONTENT -->
        <div class="content-body">
            <div class="cards-grid">

                <a href="/book-review" class="db-card">
                    <p class="card-title">Book Review</p>
                </a>

                <a href="/book-items" class="db-card">
                    <p class="card-title">Book List</p>
                </a>

                <a href="/book-transaction" class="db-card">
                    <p class="card-title">Book Transaction</p>
                </a>

                <a href="/book-borrow" class="db-card">
                    <p class="card-title">Book Borrow</p>
                </a>

            </div>
        </div>

    </div>
</div>

@code {
    private void Logout()
    {
        Navigation.NavigateTo("/login", true);
    }

    private MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#1a7a4e",
            Background = "#f4faf7"
        }
    };
}